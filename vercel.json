{
  "crons": [
    { "path": "/api/auto-stamp", "schedule": "0 3 * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "sector317.com" }],
      "destination": "https://www.sector317.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/leaderboard.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "rewrites": [
    { "source": "/leaderboard.html", "destination": "/leaderboard.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}